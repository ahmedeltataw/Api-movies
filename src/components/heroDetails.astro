---
import { Image } from "astro:assets";
import controlImg from "../assets/img/slider-control.jpg";
import backImg from '../assets/img/slider-banner.jpg'
---

<section class="hero-details" aria-label="banner-detailsPage">
  <div class="inner-hero ">
    <div class="details-box d-flex align-items-start">
      <div class="backdrop-img" >
        <Image src={backImg} alt="img" quality={20} format="avif" class='img-cover' loading="eager" />
      </div>
      <figure>
        <Image
          src={controlImg}
          alt="s"
          quality={20}
          format="avif"
          class="img-cover poster-box"
        />
      </figure>
      <div class="details-content">
        <h3 class="title-banner fs-r-48 fw-700">
          Sound of Freedom Sound of Freedom
        </h3>
        <div class="details mt-6">
          <div class="review d-flex align-items-center mx-2">
            <div class="rate">
              <i class="bi bi-star-fill fs-12"></i>
              <span class="fs-r-16"> 7.5</span>
            </div>
            <p class="time-movie fs-r-16 round-4">160m</p>
            <p class="data fs-r-16 round-4">2005</p>
            <p class="data fs-r-16 rate-badge py-2 px-4 round-4">PG-13</p>
          </div>
          <p class="gener my-6 mx-4">Action,Adventure,Animation,Comedy</p>
          <p class="overview mb-10 mx-4">
            Amid a future war between the human race and the forces of
            artificial intelligence, a hardened ex-special forces agent grieving
            the disappearance of his wife, is recruited to hunt down and kill
            the Creator, the elusive architect of advanced AI who has developed
            a mysterious weapon with the power to end the war—and mankind
            itself."
          </p>
          <ul class="details-actor mb-10">
            <li class="info-actor d-flex align-items-start mb-6">
              <p class="title-actor fw-700">Starring</p>
              <p class="info">
                Letitia Wright, Lupita Nyong'o, Danai Gurira, Winston Duke,
                Dominique Thorne, Tenoch Huerta Mejía, Angela Bassett, Florence
                Kasumba, Michaela Coel, Mabel Cadena
              </p>
            </li>
            <li class="info-actor d-flex align-items-center">
              <p class="title-actor fw-700">Directed By</p>
              <p class="info">Ryan Coogler</p>
            </li>
          </ul>
        </div>
        <!--  -->

        
        

        <!--  -->
      </div>
    </div>
    <div class="video-swiper mt-13">
          <p class="fs-r-24 fw-700 title-banner mb-10">Trailers and Clips</p>
          <div class="innerr-slider d-flex align-items-center">
            <div class="video-card"></div>
            <div class="video-card"></div>
            <div class="video-card"></div>
            <div class="video-card"></div>
            <div class="video-card"></div>
          </div>
        </div>
  </div>
</section>
<style lang="scss">
  .inner-hero {
    min-height: 600px;
    // overflow: hidden;
    width: 100%;
    .backdrop-img{
      
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 800px;
      z-index: -1;
      
      &::after{
        content: '';
        position: absolute;
        inset: 0;
        background-image: linear-gradient(0deg , hsla(250 , 13% , 11% ,1) , hsla(250,13%,11%,.9));
      }
      &::before{
        content: '';
        position: absolute;
        bottom: 0;
        left: 0;
        background-image: linear-gradient(180deg, hsla(250, 13%, 11%, 0), hsla(250, 6%, 20%, 1));
        width: 100%;
        height: 200px;
        z-index: 9;
      }
    }
    .details-box {
      gap: 32px;
      @media (max-width: 767px) {
        flex-wrap: wrap;
      }
      figure {
        width: 300px;

        @media (max-width: 767px) {
          margin: 0 auto;
        }
        @media (max-width: 480px) {
          width: 250px;
        }
      }
      .details-content {
        width: 100%;
        max-width: 700px;
        
        .details {
          
          color: var(--text-color);
          .review {
            gap: 12px;
            .rate {
              i {
                color: var(--rating-color);
                margin-right: 2px;
              }
            }
          }
        }
        .title-actor {
          min-width: 110px;
          color: var(--white);
          text-transform: capitalize;
        }
        .overview , .info{
          line-height: 1.5;
        }
      }
    }
    .video-card {
      max-width: 500px;
      width: calc(100% - 40px);
    }
    
    .innerr-slider {
      overflow-x: auto;
      gap: 12px;
      
    }
    :global(.title-banner) {
          color: var(--white);
          
        }
  }
</style>
