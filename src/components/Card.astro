---
interface Props {
  title: string;
  year: number;
  rate: number;
  href: string;
  img: any;
  alt: string;
}

const { href, title, year,rate,img ,alt} = Astro.props;
import { Image } from "astro:assets";

---

<div class="card-box relative">
  <figure>
    <Image
      src={img}
      alt= {alt}
      quality={20}
      format="avif"
      class="img-cover poster-box"
    />
  </figure>
  <h5 class="title-moive fs-r-20 fw-700 py-7">
    {title}
  </h5>
  <div class="review d-flex align-items-center justify-space-between">
    <div class="rate">
      <i class="bi bi-star-fill fs-12"></i>
      <span class="fs-r-18 fw-700">  {rate} </span>
    </div>
    <p class="data fs-r-16 rate-badge py-2 px-4 round-4"> {year} </p>
  </div>
  <a href={href} title="Sound of Freedom Sound of Freedom" class="card-btn"></a>
</div>
<style lang="scss">
  .card-box {
    
    width: 200px;
    max-width: 100%;
	

    figure {
      width: 100%;
      box-shadow: var(--shadow-1);
      border-radius: 16px;
    }
    .title-moive {
      color: var(--white);
      white-space: nowrap;
      text-overflow: ellipsis;
      overflow: hidden;
      width: 100%;
    }
    .review {
      gap: 12px;
      color: var(--text-color);
	  .rate{
		
		i{
		color: var(--rating-color);
		margin-right: 5px;
	  }
	  }
    }
	.card-btn{
		position: absolute;
		inset: 0;
	}
  }
</style>
